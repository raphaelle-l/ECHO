<script>
  const ghost      = document.getElementById('drag-ghost');
  const ghostIcon  = document.getElementById('ghost-icon');
  const speakerBox = document.getElementById('speakerBox');
  const slot       = document.getElementById('speakerSlot');
  const slotIcon   = document.getElementById('slotIcon');
  const slotName   = document.getElementById('slotName');
  const badge      = document.getElementById('nowPlayingBadge');
  const badgeTxt   = document.getElementById('nowPlayingText');
  let dragged = null, activeAudio = null, occupant = null;

  document.addEventListener('mousemove', e => { if (dragged) moveGhost(e.clientX, e.clientY); });
  document.addEventListener('touchmove', e => {
    if (dragged) { moveGhost(e.touches[0].clientX, e.touches[0].clientY); e.preventDefault(); }
  }, { passive: false });

  function moveGhost(x, y) {
    ghost.style.left = x + 'px'; ghost.style.top = y + 'px';
    const r = slot.getBoundingClientRect();
    slot.classList.toggle('drag-over', x > r.left && x < r.right && y > r.top && y < r.bottom);
  }

  document.querySelectorAll('.fig-item').forEach(f => {
    f.addEventListener('mousedown',  e => startDrag(f, e.clientX, e.clientY));
    f.addEventListener('touchstart', e => startDrag(f, e.touches[0].clientX, e.touches[0].clientY), { passive: true });
  });

  function startDrag(f, x, y) {
    if (f.classList.contains('on-speaker')) return;
    dragged = f;
    ghostIcon.textContent = f.dataset.icon;
    ghost.style.cssText = `display:flex;left:${x}px;top:${y}px`;
    f.classList.add('dragging');
  }

  document.addEventListener('mouseup',  endDrag);
  document.addEventListener('touchend', endDrag);

  function endDrag(e) {
    if (!dragged) return;
    ghost.style.display = 'none';
    slot.classList.remove('drag-over');
    const x = e.changedTouches ? e.changedTouches[0].clientX : e.clientX;
    const y = e.changedTouches ? e.changedTouches[0].clientY : e.clientY;
    const r = slot.getBoundingClientRect();
    if (x > r.left - 24 && x < r.right + 24 && y > r.top - 24 && y < r.bottom + 24) place(dragged);
    dragged.classList.remove('dragging');
    dragged = null;
  }

  function place(f) {
    if (occupant) ejectFig(false);
    occupant = f; f.classList.add('on-speaker');
    slotIcon.textContent = f.dataset.icon;
    slotName.textContent = f.dataset.label;
    slot.classList.add('occupied');
    speakerBox.classList.add('active');
    badge.classList.add('visible');
    badgeTxt.textContent = f.dataset.label + ' track';
    if (f.dataset.src) {
      if (activeAudio) { activeAudio.pause(); activeAudio = null; }
      activeAudio = new Audio(f.dataset.src);
      activeAudio.loop = true;
      activeAudio.play().catch(() => {});
    }
  }

  function ejectFig(r = true) {
    if (!occupant) return;
    occupant.classList.remove('on-speaker'); occupant = null;
    slot.classList.remove('occupied');
    slotIcon.textContent = ''; slotName.textContent = '';
    speakerBox.classList.remove('active');
    badge.classList.remove('visible');
    if (activeAudio) { activeAudio.pause(); activeAudio = null; }
  }
</script>
