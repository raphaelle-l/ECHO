<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Echo Was Here</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:      #1939cb;
      --grid:      #1b43f0;
      --black:     #0a0a0a;
      --white:     #ffffff;
      --off-white: #f4f0e8;
      --nav-h:     52px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      font-family: 'DM Sans', sans-serif;
      color: var(--off-white);
      overflow-x: hidden;
      cursor: crosshair;
    }

    /* grain overlay */
    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 9998;
      pointer-events: none; opacity: .032;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 180px 180px;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: var(--nav-h);
      display: flex; justify-content: space-between; align-items: stretch;
      background: #1b43f0;
      background-image:
        linear-gradient(rgba(25,57,203,0.7) 1px, transparent 1px),
        linear-gradient(90deg, rgba(25,57,203,0.7) 1px, transparent 1px);
      background-size: 14px 14px;
    }
    .nav-left {
      display: flex; align-items: center; gap: 10px;
      padding: 0 20px; border-right: 1px solid rgba(25,57,203,0.35);
    }
    .social-icons { display: flex; gap: 6px; }
    .social-icon {
      width: 24px; height: 24px;
      border: 1.5px solid var(--black); border-radius: 3px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; opacity: .6; color: var(--black);
      transition: opacity .12s, transform .12s;
    }
    .social-icon:hover { opacity: 1; transform: translateY(-1px); }
    nav ul { list-style: none; display: flex; align-items: stretch; }
    nav ul li { border-left: 1px solid rgba(25,57,203,0.35); }
    nav ul a {
      display: flex; align-items: center;
      padding: 0 20px; height: 100%;
      color: var(--black); text-decoration: none;
      font-family: 'Space Mono', monospace;
      font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
      opacity: .75; transition: opacity .12s, background .12s;
    }
    nav ul a:hover { opacity: 1; background: rgba(0,0,0,.1); }

    /* ── SECTION 1 · HOME ── */
    #home {
      height: 100vh; min-height: 600px;
      background-color: var(--blue);
      background-image:
        linear-gradient(rgba(27,67,240,0.45) 1px, transparent 1px),
        linear-gradient(90deg, rgba(27,67,240,0.45) 1px, transparent 1px);
      background-size: 14px 14px;
      position: relative; overflow: hidden;
      display: flex; flex-direction: column; justify-content: flex-end;
    }



    .tag-img-wrap {
      position: absolute; top: 50%; left: 38%;
      transform: translate(-50%, -50%) rotate(-4deg);
      z-index: 7; width: 72vw; max-width: 1000px;

    }
    .tag-png {
      width: 100%; height: auto; display: block;
      mix-blend-mode: multiply;
    }
    .home-silhouette {
      position: absolute;
      bottom: 44px; /* sit just above the index bar */
      right: 4vw;
      height: calc(100vh - 44px); /* nearly full viewport height */
      width: auto;
      display: block;
      mix-blend-mode: screen;
      opacity: .92;
      z-index: 6;
      filter: drop-shadow(0 0 40px rgba(25,57,203,.2));

    }
    /* zero-height anchor — takes no space in flow */
    /* top half: anchor at bottom of story, clip box sits above, text at top = top half shows */


    /* drip */
    .drip-wrap { position: relative; display: inline-block; }
    .drip-wrap::after {
      content: ''; position: absolute; bottom: -3px; right: 10px;
      width: 12px; height: 0; background: var(--black);
      border-radius: 0 0 12px 12px;
      animation: drip1 2.6s cubic-bezier(.25,.1,.1,1) both;
      animation-delay: 1.2s;
    }
    @keyframes drip1 {
      0%   { height: 0; opacity: 0; }
      8%   { opacity: 1; }
      55%  { height: 82px; }
      70%  { height: 94px; }
      80%  { height: 88px; }
      100% { height: 102px; }
    }
    .drip-thin {
      position: absolute; bottom: -3px; right: 27px;
      width: 6px; height: 0; background: var(--black);
      border-radius: 0 0 6px 6px;
      animation: drip2 2s cubic-bezier(.25,.1,.15,1) both;
      animation-delay: 1.65s;
    }
    @keyframes drip2 {
      0%   { height: 0; opacity: 0; }
      12%  { opacity: 1; }
      100% { height: 50px; }
    }
    .drip-drop {
      position: absolute; width: 17px; height: 12px;
      border-radius: 50%; background: var(--black);
      bottom: -108px; right: 2px; opacity: 0;
      animation: dropPop .18s ease both; animation-delay: 3.7s;
    }
    @keyframes dropPop {
      0%   { opacity: 0; transform: scale(.1); }
      100% { opacity: 1; transform: scale(1); }
    }

    .tag-caption {
      margin-top: 16px;
      font-family: 'Space Mono', monospace;
      font-size: .62rem; letter-spacing: .2em; text-transform: uppercase;
      color: var(--black); opacity: .5;
      animation: fadeUp .8s ease both; animation-delay: .9s;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .can-wrap {
      position: absolute; bottom: -8px; right: 5vw; z-index: 10;
      opacity: 0;
      animation: canIn .85s cubic-bezier(.22,1,.36,1) both;
      animation-delay: 2.4s;
    }
    .cap-wrap {
      position: absolute; bottom: 20px; right: calc(5vw - 44px); z-index: 10;
      opacity: 0;
      animation: canIn .6s ease both; animation-delay: 2.8s;
    }
    @keyframes canIn {
      0%   { opacity: 0; transform: translateY(28px) rotate(7deg); }
      100% { opacity: 1; transform: translateY(0) rotate(3deg); }
    }

    .home-index {
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 44px; background: var(--black);
      display: flex; align-items: stretch; z-index: 10;
    }
    .home-index-item {
      flex: 1;
      display: flex; align-items: center; justify-content: center;
      border-right: 1px solid rgba(255,255,255,.08);
      font-family: 'Space Mono', monospace;
      font-size: .58rem; letter-spacing: .18em; text-transform: uppercase;
      color: rgba(255,255,255,.35); gap: 10px;
    }
    .home-index-item:last-child { border-right: none; }
    .home-index-num { font-size: .5rem; color: rgba(255,255,255,.2); }

    /* ── SECTION 2 · STORY ── */
    #story {
background-image: url(Doodle_background.png)
;      background-size: cover;
      background-position: center;
      color: var(--black);
      position: relative; overflow: visible;
    }
    #story::before {
      content: '';
      position: absolute; inset: 0;
      background: var(--off-white);
      opacity: .88;
      z-index: 0;
      pointer-events: none;
    }
    /* ensure all story children sit above the overlay */
    #story > * { position: relative; z-index: 1; }

    .story-bar {
      display: flex; align-items: center;
      border-bottom: 2px solid var(--black);
      position: relative; z-index: 1;
    }
    .story-bar-label {
      font-family: 'Space Mono', monospace;
      font-size: .62rem; letter-spacing: .22em; text-transform: uppercase;
      opacity: .45; padding: 14px 24px;
      border-right: 2px solid var(--black);
    }
    .story-bar-num {
      font-family: 'Space Mono', monospace;
      font-size: .62rem; letter-spacing: .1em;
      opacity: .25; padding: 14px 24px;
    }

    .video-wrap {
      position: relative; width: 100%; aspect-ratio: 16/9;
      background: var(--black); overflow: hidden;
      border-bottom: 2px solid var(--black);
      display: flex; align-items: center; justify-content: center;
      z-index: 1;
    }
    .video-placeholder {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 14px;
      color: rgba(255,255,255,.2);
      font-family: 'Space Mono', monospace;
      font-size: .72rem; letter-spacing: .12em;
    }
    .video-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }

    .story-body-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      position: relative; z-index: 1;
    }
    .story-col-a {
      border-right: 2px solid var(--black);
      padding: 60px 48px 80px;
    }
    .story-heading {
      font-family: 'DM Sans', sans-serif; font-weight: 700;
      font-size: clamp(64px, 9vw, 128px);
      line-height: .86; letter-spacing: -.04em;
      color: var(--black); margin-bottom: 36px;
    }
    .story-body-text {
      font-size: .95rem; line-height: 1.78; font-weight: 300; opacity: .7;
      max-width: 380px;
    }
    .story-body-text p + p { margin-top: 16px; }
    .story-body-text strong { font-weight: 500; opacity: 1; }

    .story-col-b {
      padding: 60px 48px 80px;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .story-pull {
      font-family: 'DM Sans', sans-serif; font-weight: 700;
      font-size: clamp(26px, 3.5vw, 42px);
      line-height: 1.15; letter-spacing: -.03em; color: var(--black);
    }
    .story-detail {
      font-family: 'Space Mono', monospace;
      font-size: .6rem; letter-spacing: .18em; text-transform: uppercase;
      opacity: .3; border-top: 1px solid rgba(0,0,0,.15);
      padding-top: 20px; margin-top: 40px;
    }

    /* ── SECTION 3 · SPEAKER INTRO ── */
    #speaker-intro { overflow: hidden; position: relative; }

    .sp-panel-a {
      background: #0e0e0e; min-height: 90vh;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; position: relative; overflow: visible;
    }
    .sp-text-a {
      padding: 100px 6vw 80px;
      border-right: 2px solid rgba(255,255,255,.06);
      position: relative; z-index: 2;
    }
    .sp-eyebrow {
      font-family: 'Space Mono', monospace; font-size: .6rem;
      letter-spacing: .28em; text-transform: uppercase;
      color: var(--off-white); opacity: .3;
      margin-bottom: 28px; display: flex; align-items: center; gap: 12px;
    }
    .sp-eyebrow::before {
      content: ''; display: block; width: 28px; height: 1px; background: currentColor;
    }
    .sp-heading-a {
      font-family: 'DM Sans', sans-serif; font-weight: 700;
      font-size: clamp(52px, 7.5vw, 112px);
      line-height: .86; letter-spacing: -.04em;
      color: var(--off-white); margin-bottom: 40px;
    }
    .sp-heading-a em {
      color: var(--blue); font-style: normal;
    }
    .sp-body-a {
      font-size: .95rem; line-height: 1.78; opacity: .45;
      max-width: 380px; font-weight: 300;
      border-left: 2px solid var(--blue); padding-left: 16px;
    }

    .sp-stats {
      display: flex; gap: 0; margin-top: 40px;
      border-top: 1px solid rgba(255,255,255,.1);
      padding-top: 28px;
    }
    .sp-stat {
      display: flex; flex-direction: column; gap: 4px;
      padding: 0 28px;
      border-left: 1px solid rgba(255,255,255,.1);
    }
    .sp-stat:first-child { padding-left: 0; border-left: none; }
    .sp-stat-n {
      font-family: 'DM Sans', sans-serif; font-weight: 700;
      font-size: 2.8rem; line-height: 1; color: var(--off-white);
    }
    .sp-stat-l {
      font-family: 'Space Mono', monospace;
      font-size: .58rem; letter-spacing: .2em; text-transform: uppercase;
      color: var(--off-white); opacity: .35;
    }

        .sp-speaker-hero {
      display: flex; justify-content: center; align-items: flex-end;
      position: relative; z-index: 10; padding: 80px 6vw 0;
    }
    .sp-speaker-3d {
      width: clamp(260px, 34vw, 500px);
      filter: drop-shadow(-24px 36px 70px rgba(0,0,0,.95)) drop-shadow(0 0 60px rgba(25,57,203,.2));
      margin-bottom: -120px;
    }
    .sp-speaker-3d svg, .sp-speaker-3d img { width: 100%; height: auto; display: block; }

    /* ── SECTION 4 · MUSIC ── */
    #music { background: var(--off-white); color: var(--black); position: relative; overflow: visible; }

    .music-bar {
      display: flex; align-items: stretch;
      border-bottom: 2px solid rgba(0,0,0,.1);
      position: relative; z-index: 1;
    }
    .music-bar-title {
      padding: 24px 32px;
      border-right: 2px solid rgba(0,0,0,.1);
      flex: 1;
    }
    .music-label {
      font-family: 'Space Mono', monospace; font-size: .6rem;
      letter-spacing: .25em; text-transform: uppercase;
      opacity: .4; margin-bottom: 10px; display: block;
    }
    .music-heading {
      font-family: 'DM Sans', sans-serif; font-weight: 700;
      font-size: clamp(36px, 5vw, 68px);
      line-height: .88; letter-spacing: -.03em;
    }
    .music-sub {
      font-family: 'Space Mono', monospace;
      font-size: .65rem; letter-spacing: .15em; text-transform: uppercase;
      opacity: .45; color: var(--black); margin-top: 10px; display: block;
    }

    .player-wrap {
      flex: 1; max-width: 580px; min-width: 260px;
      background: #f0ece4;
      border-left: 2px solid rgba(0,0,0,.1);
      display: flex; align-items: center; padding: 24px 32px;
    }
    .player-inner { width: 100%; display: flex; flex-direction: column; gap: 10px; }
    .player-track-name {
      font-family: 'DM Sans', sans-serif; font-weight: 700;
      font-size: 1.2rem;
    }
    .player-artist {
      font-family: 'Space Mono', monospace;
      font-size: .62rem; letter-spacing: .15em; text-transform: uppercase; opacity: .45; color: var(--black);
    }
    .player-bar {
      width: 100%; height: 2px;
      background: rgba(0,0,0,.12);
      position: relative; margin-top: 4px;
    }
    .player-bar::after {
      content: ''; position: absolute; left: 0; top: 0;
      width: 35%; height: 100%; background: var(--black);
    }
    .player-note { font-size: .65rem; opacity: .35; color: var(--black); letter-spacing: .08em; font-style: italic; }
    .player-wrap iframe { width: 100%; border: none; display: block; }

    .music-interact { padding: 72px 5vw 120px; position: relative; z-index: 1; }

    .interact-label {
      display: flex; align-items: center; gap: 16px;
      font-family: 'Space Mono', monospace;
      font-size: .62rem; letter-spacing: .24em; text-transform: uppercase;
      opacity: .4; color: var(--black); margin-bottom: 52px;
    }
    .interact-label::after { content: ''; flex: 1; height: 1px; background: rgba(0,0,0,.12); }

    /* interact layout */
    .interact-scene {
      display: flex; flex-direction: column; align-items: center;
      gap: 0; max-width: 700px; margin: 0 auto;
    }

    /* shelf row */
    .shelf-row { width: 100%; }
    .shelf-figs {
      display: flex; justify-content: center; gap: 48px;
      align-items: flex-end; padding-bottom: 20px;
    }
    .shelf-line {
      width: 100%; height: 3px;
      background: var(--black);
      box-shadow: 0 4px 12px rgba(0,0,0,.15);
    }

    /* speaker row */
    .speaker-row {
      width: 100%; display: flex; flex-direction: column;
      align-items: center; padding-top: 0;
    }
    .speaker-drop-zone {
      width: 480px; height: 120px;
      border: 2px dashed rgba(0,0,0,.18);
      border-bottom: none;
      border-radius: 8px 8px 0 0;
      display: flex; align-items: center; justify-content: center;
      margin-top: 40px;
      transition: border-color .2s, background .2s;
      position: relative;
    }
    .speaker-drop-zone.drag-over {
      border-color: var(--blue); background: rgba(25,57,203,.06);
    }
    .speaker-drop-zone.drag-over .slot-hint { color: var(--blue); }
    .speaker-drop-zone.occupied {
      border-style: solid; border-color: rgba(0,0,0,.12);
    }
    .slot-hint {
      font-family: 'Space Mono', monospace;
      font-size: .6rem; letter-spacing: .14em; text-transform: uppercase;
      color: rgba(0,0,0,.25);
    }

    /* figurine */
    .fig-item {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      cursor: grab; user-select: none; touch-action: none;
      transition: transform .18s, opacity .18s;
    }
    .fig-item:hover { transform: translateY(-10px); }
    .fig-item:active { cursor: grabbing; }
    .fig-item.dragging { opacity: .15; transform: scale(.86); pointer-events: none; }
    .fig-item.on-speaker { opacity: .12; transform: scale(.84); pointer-events: none; }
    .fig-body {
      width: 100px; height: 140px;
      background: transparent;
      border-radius: 6px;
      display: flex; align-items: flex-end; justify-content: center;
      overflow: hidden; position: relative;
    }
    .fig-card-img {
      width: 100%; height: 100%; object-fit: contain;
      mix-blend-mode: multiply;
      pointer-events: none; display: block;
    }
    .fig-body::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0;
      height: 3px; border-radius: 10px 10px 0 0;
    }
    .fig-item[data-track="drums"]  .fig-body::before { background: var(--blue); }
    .fig-item[data-track="bass"]   .fig-body::before { background: var(--blue); }
    .fig-item[data-track="guitar"] .fig-body::before { background: var(--blue); }
    .fig-item[data-track="keys"]   .fig-body::before { background: var(--blue); }
    .fig-body img { width: 85%; height: 85%; object-fit: contain; pointer-events: none; }
    .fig-emoji { font-size: 2.2rem; pointer-events: none; }
    .fig-base {
      width: 30px; height: 6px;
      background: linear-gradient(180deg, #333 0%, #222 100%);
      border-radius: 3px; box-shadow: 0 2px 6px rgba(0,0,0,.5);
    }
    .fig-label {
      font-family: 'Space Mono', monospace;
      font-size: .55rem; letter-spacing: .1em; text-transform: uppercase;
      opacity: .38; text-align: center;
    }

    /* speaker */

    .speaker-box {
      width: 480px;
      background: transparent;
      padding: 0;
      position: relative;
    }
    .speaker-img {
      width: 100%; height: auto; display: block;
      filter: drop-shadow(0 8px 32px rgba(0,0,0,.2));
    }
    .speaker-box.active .speaker-img {
      filter: drop-shadow(0 8px 32px rgba(25,57,203,.4)) drop-shadow(0 0 20px rgba(25,57,203,.2));
    }
    .speaker-box.active
    .speaker-box.active
    .slot-hint { pointer-events: none; }
    .slot-fig { display: none; align-items: center; gap: 8px; width: 100%; padding: 0 10px; }
    .speaker-drop-zone.occupied .slot-fig { display: flex; }
    .speaker-drop-zone.occupied .slot-hint { display: none; }
    .slot-fig-icon { font-size: 1rem; }
    .slot-fig-name {
      font-family: 'Space Mono', monospace;
      font-size: .6rem; color: var(--off-white); flex: 1; letter-spacing: .08em;
    }
    .slot-eject {
      font-family: 'Space Mono', monospace;
      font-size: .52rem; letter-spacing: .08em;
      color: rgba(255,255,255,.28); cursor: pointer;
      padding: 2px 7px; border-radius: 3px;
      transition: color .15s, background .15s;
    }
    .slot-eject:hover { color: var(--off-white); background: rgba(255,255,255,.08); }
    .speaker-strip {
      display: flex; justify-content: space-between; align-items: center; padding: 0 2px;
    }
    .speaker-brand {
      font-family: 'Space Mono', monospace;
      font-size: .52rem; opacity: .35; letter-spacing: .14em; text-transform: uppercase;
    }
    .speaker-led {
      width: 7px; height: 7px; border-radius: 50%;
      background: #1a1a1a; border: 1px solid #2a2a2a;
      transition: background .3s, box-shadow .3s;
    }
    .speaker-box.active .speaker-led { background: var(--blue); box-shadow: 0 0 10px var(--blue); }
    .speaker-base {
      width: 230px; height: 12px;
      background: linear-gradient(180deg, #272727 0%, #181818 100%);
      border-radius: 0 0 8px 8px;
      border: 1px solid rgba(255,255,255,.04); border-top: none;
      box-shadow: 0 8px 24px rgba(0,0,0,.5);
    }
    .now-playing-badge {
      display: flex; align-items: center; gap: 8px;
      font-family: 'Space Mono', monospace;
      font-size: .6rem; letter-spacing: .14em; text-transform: uppercase;
      color: var(--blue); height: 22px; margin-top: 14px;
      opacity: 0; transition: opacity .3s;
    }
    .now-playing-badge.visible { opacity: 1; }
    .badge-waves { display: flex; align-items: center; gap: 2px; }
    .badge-waves span {
      display: block; width: 2px; background: var(--blue); border-radius: 2px;
      animation: wave .75s ease-in-out infinite;
    }
    .badge-waves span:nth-child(1) { height: 4px;  animation-delay: 0s; }
    .badge-waves span:nth-child(2) { height: 11px; animation-delay: .12s; }
    .badge-waves span:nth-child(3) { height: 6px;  animation-delay: .24s; }
    .badge-waves span:nth-child(4) { height: 9px;  animation-delay: .08s; }
    @keyframes wave {
      0%, 100% { transform: scaleY(1); }
      50%       { transform: scaleY(.28); }
    }

    .audio-note {
      margin-top: 48px;
      font-family: 'Space Mono', monospace;
      font-size: .6rem; letter-spacing: .1em; opacity: .3; color: var(--black);
      font-style: italic; max-width: 500px; line-height: 1.8;
    }

    /* drag ghost */
    #drag-ghost {
      position: fixed; pointer-events: none; z-index: 9999;
      transform: translate(-50%, -50%) scale(1.14) rotate(5deg);
